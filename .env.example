# Public WordPress REST API base (include /wp/v2).
# Leave unset to use the default live site (blogs.supershyft.com).
# Set to "demo" for offline placeholder content only.
# Example override: https://your-site.com/wp-json/wp/v2
# VITE_WP_API_BASE=

# Optional: override header links (defaults to www.supershyft.com pages if unset)
# VITE_NAV_OUR_TECH=https://www.supershyft.com/technology.html
# VITE_NAV_ABOUT=https://www.supershyft.com/our-story.html
# VITE_NAV_CONTACT=https://www.supershyft.com/contact-us.html
